{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://traveller-production-1a3d.up.railway.app/api/:path*"
    },
    {
      "source": "/",
      "destination": "/static/index.html"
    },
    {
      "source": "/static/:path*",
      "destination": "/static/:path*"
    }
  ]
}